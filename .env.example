# Server & Application Configuration
NODE_ENV=development
PORT=5000

# Database Path (Relative to server/ directory)
DATABASE_PATH=./db/faidaplus.db

# JWT Configuration (Choose a strong, random secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration (Optional, comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini API Integration (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: Used for production self-referential links or callbacks
APP_URL=http://localhost:3000

